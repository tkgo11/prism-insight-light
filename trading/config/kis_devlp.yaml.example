# KIS Developer API 설정 파일 예시
# 1) 이 파일을 trading/config/kis_devlp.yaml 로 복사하세요.
# 2) [필수] 표시가 있는 값만 먼저 채우면 기본 실행이 가능합니다.
# 3) 실전/모의 계좌를 동시에 쓰거나 계좌가 여러 개면 accounts 항목의 예시 블록을 복사해 추가하세요.

# -----------------------------------------------------------------------------
# 1. 기본 실행 설정
# -----------------------------------------------------------------------------

# [필수] 기본 매매 환경
# - demo: 모의투자
# - real: 실전투자
# 안전을 위해 처음에는 demo 권장
default_mode: demo

# 자동매매 작동 여부
# - false: 설정/연결 확인용
# - true : 실제 주문 실행
auto_trading: true

# 종목별 기본 매수 금액
default_unit_amount: 10000       # 한국 주식 1회 기본 매수 금액 (KRW)
default_unit_amount_usd: 100     # 미국 주식 1회 기본 매수 금액 (USD)

# 기본 상품 코드
# 일반 주식 계좌는 보통 "01" 그대로 사용합니다.
# 01: 종합계좌, 03: 국내선물옵션, 08: 해외선물옵션, 22: 개인연금, 29: 퇴직연금
default_product_code: "01"

# -----------------------------------------------------------------------------
# 2. KIS API 키 / HTS ID
# -----------------------------------------------------------------------------

# [필수] 한국투자증권 HTS 로그인 ID
my_htsid: "HTS_ID_입력"

# [필수] App Key / App Secret
# - KIS API는 App Key 1개가 계좌번호 1개에 바인딩됩니다.
# - 단일 계좌라면 여기만 채우고 accounts 안의 app_key/app_secret은 생략해도 됩니다.
# - 여러 계좌라면 계좌별 app_key/app_secret을 accounts 안에 각각 입력하세요.
# - 쓰지 않는 환경의 키가 아직 없다면 빈 문자열("")로 두고, 해당 mode 계좌를 만들지 마세요.

# 실전투자용 키 (real 계좌에서 사용)
my_app: ""      # 예: PS... 로 시작하는 실전 App Key
my_sec: ""      # 실전 App Secret

# 모의투자용 키 (demo 계좌에서 사용)
paper_app: ""   # 예: PSVT... 로 시작하는 모의투자 App Key
paper_sec: ""   # 모의투자 App Secret

# -----------------------------------------------------------------------------
# 3. 계좌 설정
# -----------------------------------------------------------------------------

# [필수] 최소 1개 계좌를 입력하세요.
# 계좌번호가 12345678-01 이라면:
#   account: "12345678"
#   product: "01"
#
# 필드 빠른 설명:
#   name    : 로그에 보일 계좌 이름
#   mode    : real 또는 demo
#   market  : kr(국내), us(미국), all(국내+미국)
#   account : 계좌번호 앞 8자리
#   product : 계좌번호 뒤 2자리, 일반 주식은 보통 "01"
#   primary : 같은 조건의 계좌가 여러 개일 때 우선 사용할 계좌인지 여부
#
# 단일 계좌 예시입니다. 필요 없거나 쓰지 않는 예시는 지우거나 주석 처리하세요.
accounts:
  - name: "모의-메인"
    mode: "demo"
    market: "all"
    account: "12345678"
    product: "01"
    primary: true
    # 단일 계좌는 위 paper_app/paper_sec 또는 my_app/my_sec 값을 자동 사용합니다.
    # 이 계좌 전용 키를 직접 지정하려면 아래 두 줄의 #을 지우고 입력하세요.
    # app_key: "이_계좌_APP_KEY"
    # app_secret: "이_계좌_APP_SECRET"

  # 실전 계좌를 추가하려면 아래 예시의 #을 지우고 값만 바꾸세요.
  # - name: "실전-메인"
  #   mode: "real"
  #   market: "all"
  #   account: "23456789"
  #   product: "01"
  #   primary: true
  #   app_key: "이_계좌에_바인딩된_실전_APP_KEY"
  #   app_secret: "이_계좌에_바인딩된_실전_APP_SECRET"

  # 계좌별 매수 금액을 다르게 쓰고 싶으면 아래 값을 계좌 항목에 추가할 수 있습니다.
  #   buy_amount_krw: 50000
  #   buy_amount_usd: 200

# -----------------------------------------------------------------------------
# 4. 선택 설정
# -----------------------------------------------------------------------------

# 신호 기반 전략 설정
# - name: ""              기존 동작 유지 (전략 비활성화)
# - name: "balance_split" BUY 신호마다 현재 주문 가능 잔고의 1/split_count만 매수
signal_strategy:
  name: ""
  split_count: 2

# User-Agent
# 보통 기본값 그대로 사용해도 됩니다.
# 직접 확인하려면 Chrome > F12 개발자도구 > Console > navigator.userAgent
my_agent: "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36"

# 토큰 캐시 값입니다. 처음 설정할 때는 빈 문자열 그대로 두세요.
my_token: ""

# -----------------------------------------------------------------------------
# 5. KIS 도메인 정보 (수정하지 마세요)
# -----------------------------------------------------------------------------
prod: "https://openapi.koreainvestment.com:9443"
ops: "ws://ops.koreainvestment.com:21000"
vps: "https://openapivts.koreainvestment.com:29443"
vops: "ws://ops.koreainvestment.com:31000"
